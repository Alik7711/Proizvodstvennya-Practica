<Window x:Class="SoftwareAccountingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Информационная система учета программного обеспечения" 
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== ЗАГОЛОВОК ========== -->
        <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <TextBlock Text="📊 ИНФОРМАЦИОННАЯ СИСТЕМА УЧЕТА ПРОГРАММНОГО ОБЕСПЕЧЕНИЯ" 
                       FontSize="22" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
        </Border>

        <!-- ========== ПАНЕЛЬ ВВОДА ДАННЫХ ========== -->
        <Border Grid.Row="1" BorderBrush="#4A90D9" BorderThickness="2" CornerRadius="8" Padding="15" Margin="0,0,0,15" Background="#F8F9FA">
            <StackPanel>
                <TextBlock Text="✏️ ДОБАВЛЕНИЕ / РЕДАКТИРОВАНИЕ" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="#1E3A5F"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Строка 1 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Название ПО:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="5" Padding="8" Tag="например: Microsoft Word"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Версия:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtVersion" Grid.Row="0" Grid.Column="3" Margin="5" Padding="8" Tag="например: 2021"/>

                    <!-- Строка 2 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип лицензии:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbLicenseType" Grid.Row="1" Grid.Column="1" Margin="5" Padding="8" Height="35">
                        <ComboBoxItem Content="💰 Платная"/>
                        <ComboBoxItem Content="🎁 Бесплатная"/>
                        <ComboBoxItem Content="📅 Подписка"/>
                        <ComboBoxItem Content="⏳ Триал"/>
                        <ComboBoxItem Content="🔓 Open Source"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Производитель:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtManufacturer" Grid.Row="1" Grid.Column="3" Margin="5" Padding="8" Tag="например: Microsoft"/>

                    <!-- Строка 3 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата покупки:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <DatePicker x:Name="dpPurchaseDate" Grid.Row="2" Grid.Column="1" Margin="5" Height="35"/>

                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Стоимость (₽):" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtCost" Grid.Row="2" Grid.Column="3" Margin="5" Padding="8" Tag="только цифры"/>

                    <!-- Строка 4 -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ответственный:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtResponsible" Grid.Row="3" Grid.Column="1" Margin="5" Padding="8" Tag="ФИО сотрудника"/>

                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Кол-во пользователей:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtUserCount" Grid.Row="3" Grid.Column="3" Margin="5" Padding="8" Text="1" Tag="число"/>

                    <!-- Строка 5 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Окончание лицензии:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <DatePicker x:Name="dpExpirationDate" Grid.Row="4" Grid.Column="1" Margin="5" Height="35"/>

                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Примечания:" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtNotes" Grid.Row="4" Grid.Column="3" Margin="5" Padding="8" Tag="дополнительная информация"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========== КНОПКИ ДЕЙСТВИЙ ========== -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,15" HorizontalAlignment="Center">
            <Button x:Name="btnAdd" Content="➕ ДОБАВИТЬ" Width="130" Height="45" Margin="10" 
                    Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="14"
                    Click="BtnAdd_Click" Cursor="Hand"/>
            <Button x:Name="btnUpdate" Content="✏️ ОБНОВИТЬ" Width="130" Height="45" Margin="10" 
                    Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14"
                    Click="BtnUpdate_Click" Cursor="Hand"/>
            <Button x:Name="btnDelete" Content="🗑️ УДАЛИТЬ" Width="130" Height="45" Margin="10" 
                    Background="#E74C3C" Foreground="White" FontWeight="Bold" FontSize="14"
                    Click="BtnDelete_Click" Cursor="Hand"/>
            <Button x:Name="btnClear" Content="🧹 ОЧИСТИТЬ" Width="130" Height="45" Margin="10" 
                    Background="#95A5A6" Foreground="White" FontWeight="Bold" FontSize="14"
                    Click="BtnClear_Click" Cursor="Hand"/>
            <Button x:Name="btnRefresh" Content="🔄 ОБНОВИТЬ СПИСОК" Width="150" Height="45" Margin="10" 
                    Background="#9B59B6" Foreground="White" FontWeight="Bold" FontSize="14"
                    Click="BtnRefresh_Click" Cursor="Hand"/>
        </WrapPanel>

        <!-- ========== ТАБЛИЦА С ДАННЫМИ ========== -->
        <Border Grid.Row="3" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="8" Padding="5" Background="White">
            <StackPanel>
                <TextBlock Text="📋 СПИСОК ПРОГРАММНОГО ОБЕСПЕЧЕНИЯ" FontWeight="Bold" FontSize="14" Margin="10,5" Foreground="#1E3A5F"/>
                <DataGrid x:Name="dgSoftware" AutoGenerateColumns="True" 
                          SelectionChanged="DgSoftware_SelectionChanged" 
                          IsReadOnly="True" AlternatingRowBackground="#F8F9FA"
                          FontSize="12" RowHeight="35">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1E3A5F"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Height" Value="40"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- ========== ПАНЕЛЬ ПОИСКА И СТАТУСА ========== -->
        <Grid Grid.Row="4" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="20" Background="White" Margin="0,0,10,0">
                <TextBox x:Name="txtSearch" Margin="10,5" Padding="5" 
                         Tag="🔍 Введите название, версию или производителя..." 
                         TextChanged="TxtSearch_TextChanged"
                         Background="Transparent" BorderThickness="0"/>
            </Border>

            <Button x:Name="btnSearch" Grid.Column="1" Content="🔍 ПОИСК" Width="100" Height="35" Margin="5" 
                    Background="#F39C12" Foreground="White" FontWeight="Bold" Click="BtnSearch_Click" Cursor="Hand"/>

            <Button x:Name="btnShowAll" Grid.Column="2" Content="📋 ПОКАЗАТЬ ВСЕ" Width="120" Height="35" Margin="5" 
                    Background="#1E3A5F" Foreground="White" FontWeight="Bold" Click="BtnShowAll_Click" Cursor="Hand"/>
        </Grid>

        <!-- ========== СТРОКА СОСТОЯНИЯ ========== -->
        <StatusBar Grid.Row="5" Margin="0,10,0,0" Background="#1E3A5F" Foreground="White" Height="30">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="✅ Готов к работе"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="📁 Данные сохраняются в software.json"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>